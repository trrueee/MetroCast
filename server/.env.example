# --- AI Configuration ---
# For OpenAI:
# AI_API_KEY=sk-xxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# For Qwen (DashScope):
AI_API_KEY=your_dashscope_api_key_here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-max

# --- TTS Configuration ---
# Options: openai, cosyvoice
TTS_ENGINE=cosyvoice

# If using OpenAI TTS
OPENAI_API_KEY=sk-xxxx
OPENAI_VOICE=alloy

# If using CosyVoice (DashScope)
# Uses the same AI_API_KEY from above
COSYVOICE_VOICE=longxiaochun

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/metrocast
