# --- AI Configuration ---
# For OpenAI:
# AI_API_KEY=sk-your-openai-api-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# For Qwen (DashScope):
# AI_API_KEY=your-dashscope-api-key
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-max

# --- TTS Configuration ---
# Options: openai, cosyvoice
# TTS_ENGINE=cosyvoice

# If using OpenAI TTS
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_VOICE=alloy

# If using CosyVoice (DashScope)
# Uses the same AI_API_KEY from above
# COSYVOICE_VOICE=longxiaochun

# --- MetroCast Settings ---
# Default city for the podcast
# METROCAST_CITY=北京

# --- Background Music (optional) ---
# Set to "false" to disable background music entirely
# PODCAST_MUSIC_ENABLED=true
# Path to a royalty-free background music file (WAV or MP3).
# If not set, a gentle ambient pad is auto-generated in-memory.
# PODCAST_MUSIC_PATH=storage/music/ambient_pad.wav
# Music volume relative to speech, in dB (negative = quieter)
# PODCAST_MUSIC_VOLUME_DB=-18
# How much to lower music when speech is active (sidechain ducking)
# PODCAST_MUSIC_DUCK_DB=8

# --- Script Polish (optional) ---
# Set to "false" to disable second-pass conversational refinement
# SCRIPT_POLISH_ENABLED=true

# --- Database ---
# DATABASE_URL=sqlite:///./metrocast.db
# DATABASE_URL=postgresql://user:password@localhost:5432/metrocast
